# Copy to .env.local and fill in. Do not commit .env.local.

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=            # webhook handlers / background jobs only

# Telnyx WhatsApp Business
TELNYX_API_KEY=
TELNYX_WHATSAPP_NUMBER=+1...          # your WABA sender number (E.164)
TELNYX_PUBLIC_KEY=                    # base64 ed25519 public key from Telnyx portal, used to verify webhook signatures

# Anthropic (invoice OCR)
ANTHROPIC_API_KEY=

# Inngest (background jobs)
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=
